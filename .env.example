# Base URL of the MiHashport-Backend API this app talks to
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Stellar network PayGuard evaluates against: testnet | mainnet
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Deployed PayGuard contract ID from MiHashport-Contract (Soroban contract address)
NEXT_PUBLIC_PAYGUARD_CONTRACT_ID=
